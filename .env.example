# ═══════════════════════════════════════════════════════════
# eSewa API Wrapper — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
#
#   cp .env.example .env
#
# ⚠️  NEVER commit your .env file to version control!
# ═══════════════════════════════════════════════════════════

# Your eSewa Merchant ID (Product Code)
ESEWA_MERCHANT_ID=EPAYTEST

# Your eSewa Secret Key for HMAC signature generation
# ⚠️  Keep this secret! Never expose in client-side code.
# For sandbox/testing: 8gBm/:&EnhH.1/q
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q

# Environment: "sandbox" for testing, "production" for live
ESEWA_ENVIRONMENT=sandbox

# URL where eSewa redirects after successful payment
ESEWA_SUCCESS_URL=http://localhost:3000/payment/success

# URL where eSewa redirects after failed/cancelled payment
ESEWA_FAILURE_URL=http://localhost:3000/payment/failure
